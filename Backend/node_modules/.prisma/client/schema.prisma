generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String?
  lastName     String?
  mobileNumber String?
  email        String    @unique
  password     String?
  isVerified   Boolean   @default(false)
  otp          String?
  otpExpires   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
